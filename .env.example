# Variables de entorno para comunicación entre servicios

# ========================================
# MODO DE EJECUCIÓN (IMPORTANTE)
# ========================================
# 'single' = Un servicio individual (desarrollo distribuido)
# 'all' = Todos los servicios juntos (Docker Compose)
RUN_MODE=single

# ========================================
# URLs DE SERVICIOS (para desarrollo individual)
# ========================================
# Cuando RUN_MODE=single, usa estas URLs
AUTH_SERVICE_URL=http://localhost:3101
CART_SERVICE_URL=http://localhost:3102
CONTENT_SERVICE_URL=http://localhost:3103
ORDERS_SERVICE_URL=http://localhost:3104
PAYMENTS_SERVICE_URL=http://localhost:3105
PRODUCTS_SERVICE_URL=http://localhost:3106
IMAGE_SERVICE_URL=http://localhost:4093

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ========================================
MONGO_URL=tu_mongodb_url_aqui

# ========================================
# AUTENTICACIÓN (Google OAuth)
# ========================================
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3101/auth/google/callback

# ========================================
# PAGOS (Pagopar)
# ========================================
PAGOPAR_PUBLIC_KEY=tu_pagopar_public_key_aqui
PAGOPAR_PRIVATE_KEY=tu_pagopar_private_key_aqui

# ========================================
# CONFIGURACIÓN DE PUERTOS
# ========================================
AUTH_PORT=3101
CART_PORT=3102
CONTENT_PORT=3103
ORDERS_PORT=3104
PAYMENTS_PORT=3105
PRODUCTS_PORT=3106
IMAGE_PORT=4093

# ========================================
# VARIABLES PARA DOCKER (cuando RUN_MODE=all)
# ========================================
IS_DOCKER=false
