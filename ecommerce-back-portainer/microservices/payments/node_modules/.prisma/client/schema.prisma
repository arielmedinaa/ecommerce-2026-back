// This is your Prisma schema file for Payments Service
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model Payment {
  id                 Int       @id @default(autoincrement())
  codigoCarrito      Int
  carrito            Json // Cart object stored as JSON
  estado             String // 'pendiente' | 'procesando' | 'completado' | 'fallido' | 'cancelado' | 'reembolsado'
  metodoPago         String // 'pagopar' | 'bancard' | 'efectivo contra entrega' | 'tarjeta contra entrega'
  monto              Decimal   @db.Decimal(10, 2)
  moneda             String
  respuestaPagopar   Json? // Pagopar response stored as JSON
  respuestaBancard   Json? // Bancard response stored as JSON
  idTransaccion      String? // External transaction ID
  descripcion        String?
  cliente            Json? // Client information stored as JSON
  metadatos          Json? // Additional metadata stored as JSON
  finalizado         Boolean   @default(false)
  motivoFallo        String?
  intentosReintentar Int       @default(0)
  proximoReintento   DateTime?
  reembolsos         Json? // Refunds array stored as JSON
  procesado          Boolean   @default(false)
  expira             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("payments")
}
