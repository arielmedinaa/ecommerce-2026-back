// This is your Prisma schema file for Cart Service
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model Cart {
  id          Int      @id @default(autoincrement())
  codigo      Int
  proceso     String?
  cliente     Json? // Client object stored as JSON
  tiempo      String?
  transaccion Json? // Array stored as JSON
  seguimiento Json? // Array stored as JSON
  envio       Json? // Shipping object stored as JSON
  pago        Json? // Payment object stored as JSON
  articulos   Json? // Products object stored as JSON
  estado      String // 'activo' | 'inactivo' | 'completado' | 'cancelado'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("carritos")
}

model Llave {
  id        Int      @id @default(autoincrement())
  llave     String   @unique
  valor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("llaves")
}

model Transaccion {
  id          Int      @id @default(autoincrement())
  codigo      Int
  tipo        String // 'pago' | 'estado' | 'envio'
  descripcion String
  datos       Json? // Transaction data stored as JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("transacciones")
}
