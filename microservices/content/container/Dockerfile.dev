FROM node:20-alpine

WORKDIR /usr/src/app

RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    libc6-compat

RUN npm install -g nodemon ts-node tsconfig-paths

# Copiar package.json del proyecto raíz y del servicio
COPY package*.json ./
COPY tsconfig.paths.json ./
COPY microservices/content/package*.json ./
COPY microservices/content/tsconfig.json ./
COPY microservices/content/tsconfig.base.json ./

# Instalar dependencias del proyecto raíz primero
RUN npm install --legacy-peer-deps

# Copiar código fuente del servicio content
COPY microservices/content .

# Copiar directorio shared desde el raíz
COPY shared ./shared

RUN addgroup -S appgroup && adduser -S appuser -G appgroup
RUN chown -R appuser:appgroup /usr/src/app
USER appuser

EXPOSE 3103

CMD ["npm", "run", "start:dev"]
