generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model Category {
  id        Int      @id @default(autoincrement())
  nombre    String
  ruta      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categorias")
}

model Product {
  id                     Int      @id @default(autoincrement())
  codigo                 String?  @unique
  codigoBarra            String?
  marca                  Json?
  modelo                 String?
  nombre                 String
  ruta                   String?
  descripcion            String?  @db.Text
  venta                  Decimal? @db.Decimal(10, 2)
  ventaCredito           Json?
  costo                  Decimal? @db.Decimal(10, 2)
  precio                 Decimal  @db.Decimal(10, 2)
  cantidad               Decimal  @default(0) @db.Decimal(10, 2)
  descuento              Decimal  @default(0) @db.Decimal(10, 2)
  categorias             Json?
  subcategorias          Json?
  caracteristicas        Json?
  clasificaciones        Json?
  relaciones             Json?
  ofertas                Json?
  promos                 Json?
  proveedores            Json?
  imagenes               Json? // String array stored as JSON
  sello                  String?
  dias_ultimo_movimiento Decimal  @default(0) @db.Decimal(10, 2)
  web                    Decimal  @default(0) @db.Decimal(10, 2)
  websc                  Decimal  @default(0) @db.Decimal(10, 2)
  prioridad              Decimal  @default(0) @db.Decimal(10, 2)
  orden                  Decimal  @default(0) @db.Decimal(10, 2)
  tipo                   Decimal  @default(0) @db.Decimal(10, 2)
  estado                 Decimal  @default(1) @db.Decimal(10, 2)
  deposito               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("productos")
}

model Combo {
  id                     Int      @id @default(autoincrement())
  codigo                 String?  @unique
  codigoBarra            String?
  marca                  Json?
  modelo                 String?
  nombre                 String
  ruta                   String
  descripcion            String   @db.Text
  venta                  Decimal? @db.Decimal(10, 2)
  ventaCredito           Json?
  costo                  Decimal? @db.Decimal(10, 2)
  precio                 Decimal  @db.Decimal(10, 2)
  cantidad               Decimal  @default(0) @db.Decimal(10, 2)
  descuento              Decimal  @default(0) @db.Decimal(10, 2)
  categorias             Json?
  subcategorias          Json?
  caracteristicas        Json?
  clasificaciones        Json?
  relaciones             Json?
  ofertas                Json?
  promos                 Json?
  proveedores            Json?
  imagenes               Json? // String array stored as JSON
  sello                  String?
  dias_ultimo_movimiento Decimal  @default(0) @db.Decimal(10, 2)
  web                    Decimal  @default(1) @db.Decimal(10, 2)
  websc                  Decimal  @default(0) @db.Decimal(10, 2)
  prioridad              Decimal  @default(0) @db.Decimal(10, 2)
  orden                  Decimal  @default(0) @db.Decimal(10, 2)
  tipo                   Decimal  @default(0) @db.Decimal(10, 2)
  estado                 Decimal  @default(1) @db.Decimal(10, 2)
  deposito               String   @default("Central Shop")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("combos")
}

model ProductoOferta {
  id            Int      @id @default(autoincrement())
  nombre        String
  codigo        String
  tiempoActivo  Decimal? @db.Decimal(10, 2)
  descuento     Decimal? @db.Decimal(10, 2)
  precioContado Decimal  @db.Decimal(10, 2)
  precioCredito Decimal  @db.Decimal(10, 2)
  cuotas        Json? // Array stored as JSON
  activo        Boolean  @default(true)
  prioridad     Decimal  @default(0) @db.Decimal(10, 2)
  ofertaId      Int?
  oferta        Oferta?  @relation(fields: [ofertaId], references: [id])

  @@map("producto_ofertas")
}

model Oferta {
  id           Int              @id @default(autoincrement())
  tiempoActivo Decimal          @db.Decimal(10, 2)
  activo       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  productos    ProductoOferta[]

  @@map("ofertas")
}

model Promo {
  id              Int      @id @default(autoincrement())
  codigo          String?
  nombre          String?
  descripcion     String?  @db.Text
  ruta            String?
  fecha           String?
  hora            String?
  tiempo          Json?
  contenido       Json?
  visibilidad     Json?
  configuracion   Json?
  estado          Json?
  cantidadCliente Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("promos")
}
