generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

model Category {
  id        Int      @id @default(autoincrement())
  nombre    String
  ruta      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categorias")
}

model Product {
  id                        Int       @id @default(autoincrement())
  codigo                    String?   @unique
  codigo_articulo           String?   @unique
  nombre                    String
  familia                   String?
  subfamilia                String?
  unidad                    String?
  proveedor                 String?
  preciocosto               Decimal?  @db.Decimal(10, 2)
  precioventa               Decimal?  @db.Decimal(10, 2)
  impuesto                  Decimal?  @db.Decimal(10, 2)
  minimo                    Decimal?  @db.Decimal(10, 2)
  maximo                    Decimal?  @db.Decimal(10, 2)
  nota                      String?   @db.Text
  baja                      Boolean   @default(false)
  foto                      String?
  balanza                   Boolean   @default(false)
  nombret                   String?
  recargo                   Decimal?  @db.Decimal(10, 2)
  actualiza                 Boolean   @default(true)
  may_can                   Decimal?  @db.Decimal(10, 2)
  may_por                   Decimal?  @db.Decimal(10, 2)
  act1                      String?
  act2                      String?
  act3                      String?
  act4                      String?
  act5                      String?
  ctacompra                 String?
  ctaventa                  String?
  ctacosven                 String?
  insumo                    Boolean   @default(false)
  costofinal                Decimal?  @db.Decimal(10, 2)
  preciotope                Decimal?  @db.Decimal(10, 2)
  recargosug                Decimal?  @db.Decimal(10, 2)
  activo                    Boolean   @default(true)
  oferta_desde              DateTime?
  oferta_hasta              DateTime?
  oferta_porce              Decimal?  @db.Decimal(10, 2)
  cambioprecio              Boolean   @default(false)
  tipo_producto             String?
  ctaimporta                String?
  medidor                   Boolean   @default(false)
  moneda1                   Decimal?  @db.Decimal(10, 2)
  moneda2                   Decimal?  @db.Decimal(10, 2)
  codigodebarra             String?
  marca                     String?
  web                       Boolean   @default(false)
  websc                     Boolean   @default(false)
  desmax                    Decimal?  @db.Decimal(10, 2)
  stock                     Decimal?  @db.Decimal(10, 2)
  stock2                    Decimal?  @db.Decimal(10, 2)
  peso                      Decimal?  @db.Decimal(10, 2)
  largo                     Decimal?  @db.Decimal(10, 2)
  ancho                     Decimal?  @db.Decimal(10, 2)
  alto                      Decimal?  @db.Decimal(10, 2)
  volumen                   Decimal?  @db.Decimal(10, 2)
  gestion                   String?
  valoracion                Decimal?  @db.Decimal(10, 2)
  codigo_articulo_proveedor String?
  numero_serie              String?
  created_by                String?
  created_at                DateTime  @default(now())
  updated_by                String?
  updated_at                DateTime  @updatedAt

  @@map("articulo")
}

model Combo {
  id                     Int      @id @default(autoincrement())
  codigo                 String?  @unique
  codigoBarra            String?
  marca                  Json?
  modelo                 String?
  nombre                 String
  ruta                   String
  descripcion            String   @db.Text
  venta                  Decimal? @db.Decimal(10, 2)
  ventaCredito           Json?
  costo                  Decimal? @db.Decimal(10, 2)
  precio                 Decimal  @db.Decimal(10, 2)
  cantidad               Decimal  @default(0) @db.Decimal(10, 2)
  descuento              Decimal  @default(0) @db.Decimal(10, 2)
  categorias             Json?
  subcategorias          Json?
  caracteristicas        Json?
  clasificaciones        Json?
  relaciones             Json?
  ofertas                Json?
  promos                 Json?
  proveedores            Json?
  imagenes               Json? // String array stored as JSON
  sello                  String?
  dias_ultimo_movimiento Decimal  @default(0) @db.Decimal(10, 2)
  web                    Decimal  @default(1) @db.Decimal(10, 2)
  websc                  Decimal  @default(0) @db.Decimal(10, 2)
  prioridad              Decimal  @default(0) @db.Decimal(10, 2)
  orden                  Decimal  @default(0) @db.Decimal(10, 2)
  tipo                   Decimal  @default(0) @db.Decimal(10, 2)
  estado                 Decimal  @default(1) @db.Decimal(10, 2)
  deposito               String   @default("Central Shop")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("combos")
}

model ProductoOferta {
  id            Int      @id @default(autoincrement())
  nombre        String
  codigo        String
  tiempoActivo  Decimal? @db.Decimal(10, 2)
  descuento     Decimal? @db.Decimal(10, 2)
  precioContado Decimal  @db.Decimal(10, 2)
  precioCredito Decimal  @db.Decimal(10, 2)
  cuotas        Json? // Array stored as JSON
  activo        Boolean  @default(true)
  prioridad     Decimal  @default(0) @db.Decimal(10, 2)
  ofertaId      Int?
  oferta        Oferta?  @relation(fields: [ofertaId], references: [id])

  @@map("producto_ofertas")
}

model Oferta {
  id           Int              @id @default(autoincrement())
  tiempoActivo Decimal          @db.Decimal(10, 2)
  activo       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  productos    ProductoOferta[]

  @@map("ofertas")
}

model Promo {
  id            Int       @id @default(autoincrement())
  codigo        String?
  descripcion   String?   @db.Text
  estado        String?
  codigo_promo  Int?
  nombre_promo  String?
  fecha_inicio  DateTime?
  fecha_fin     DateTime?
  fecha_fin2    DateTime?
  fecha_inicio2 DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("tbl_promociones")
}
